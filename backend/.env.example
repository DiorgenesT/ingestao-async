# Banco de dados
# Producao: Supabase Supavisor (porta 6543, modo transaction)
# Obter password em: Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL=postgresql+asyncpg://postgres.fdjvbmwdjwbfyrxotvot:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Testes: banco separado para isolamento
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ingestao_async_test

# JWT - gerar com: openssl rand -hex 32
SECRET_KEY=SUBSTITUIR-POR-VALOR-GERADO-COM-openssl-rand-hex-32

# Ambiente: development | test | production
ENVIRONMENT=development

# CORS: origens permitidas (separadas por virgula)
# Desenvolvimento: http://localhost:5173
# Producao: https://ingestao-async.pages.dev
CORS_ORIGINS=http://localhost:5173

# Worker
WORKER_POLL_INTERVAL_SEGUNDOS=5
WORKER_BATCH_SIZE=10

# Upload de arquivos CSV
UPLOAD_DIR=/tmp/ingestao-async-uploads
