# Banco de dados
# Producao: Supabase Supavisor (porta 6543, modo transaction)
# Desenvolvimento local: docker-compose (porta 5432)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ingestao_async

# Testes: banco separado para isolamento
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ingestao_async_test

# JWT - gerar com: openssl rand -hex 32
SECRET_KEY=SUBSTITUIR-POR-VALOR-GERADO-COM-openssl-rand-hex-32

# Ambiente: development | test | production
ENVIRONMENT=development
